{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "satguruai.com" }],
      "destination": "https://app.satguruai.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.satguruai.com" }],
      "destination": "https://app.satguruai.com/:path*",
      "permanent": true
    }
  ]
}
